# Files excluded from `git archive` (npm run pack:clean) so the shared archive carries only the app —
# never the .git history, local audit log, or dev-only tooling. `.git/` and gitignored/untracked files
# (audit-log.jsonl, .env, node_modules/, dist/, client-dist/, .DS_Store) are already absent from an
# archive of HEAD; these export-ignore entries additionally drop dev-only paths from the package.
.gitattributes export-ignore
.gitignore export-ignore
.githooks/ export-ignore
.github/ export-ignore
.claude/ export-ignore
tests/ export-ignore
scripts/ export-ignore
docs/ export-ignore
