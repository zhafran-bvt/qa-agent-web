# Local development only. Railway injects PORT automatically.
QA_AGENT_PORT=5180
QA_AGENT_BASE_URL=http://localhost:5180

# Atlassian OAuth 3LO app
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
# Override only when QA_AGENT_BASE_URL is not enough. For Railway, use your public Railway domain.
ATLASSIAN_REDIRECT_URI=http://localhost:5180/auth/atlassian/callback
ATLASSIAN_SCOPES=read:jira-work read:page:confluence read:confluence-content.all read:confluence-space.summary offline_access

# LLM test-case generation
# The app tries OpenAI first, then falls back to DeepSeek on quota/rate-limit/token errors.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-pro

# F3 semantic evidence gate (optional, default OFF). When on, each "closest" acceptance-criteria
# evidence excerpt is re-checked with a cheap LLM yes/no ("does this source line state the SAME
# requirement?") so a same-topic / different-behavior line is dropped. Adds one model call per closest
# excerpt per generation, so it is strictly opt-in; off → the deterministic token-overlap scorer is the
# sole selector. Verdicts are cached and the check fails open (a transient LLM error never drops evidence).
# EXCERPT_RELEVANCE_LLM=1
# EXCERPT_RELEVANCE_LLM_CONCURRENCY=4
# EXCERPT_RELEVANCE_CACHE_TTL_MS=1800000

# Default API documentation source for API/hybrid ticket analysis.
# Supports a single OpenAPI/Swagger JSON spec or a doc portal that lists pages in doc_config.json.
# For a doc portal, only the groups in API_DOCS_GROUPS are crawled (default: Analytics + Internal BFF;
# Protocol Buffers/gRPC, Targetin, and Legacy are excluded).
API_DOCS_URL=https://dev.lokasi.com/api-docs/
# Optional crawl tuning: which groups to include, cache TTL, page-fetch concurrency, per-request timeout.
# API_DOCS_GROUPS=analytics apis,internal bff apis
# API_DOCS_CACHE_TTL_MS=1800000
# API_DOCS_CRAWL_CONCURRENCY=6
# API_DOCS_HTTP_TIMEOUT_MS=12000

# TestRail server-side service account
TESTRAIL_BASE_URL=https://bvarta.testrail.io
TESTRAIL_USER=
TESTRAIL_API_KEY=
TESTRAIL_SECTION_ID=

# Encrypts stored Atlassian session tokens and personal TestRail credentials.
ENCRYPTION_KEY=

# For local development, use the Railway public proxy host or another externally reachable Postgres host.
DATABASE_URL=postgresql://postgres:YOUR_POSTGRES_PASSWORD@YOUR_POSTGRES_HOST:5432/railway
# Optional provider CA bundle when remote Postgres needs a custom trust root.
DATABASE_CA_CERT=
